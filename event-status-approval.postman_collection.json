{
  "info": {
	"_postman_id": "b1c1c7a7-7f8d-4dbf-8c13-7d8b4a0d5f6a",
	"name": "Event Status Approval Flow",
	"description": "Import this collection into Postman to test event approval/rejection updates by event ID. Send REJECTED to store CANCELED.",
	"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
	{ "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
	{ "key": "username", "value": "your-username" },
	{ "key": "password", "value": "your-password" },
	{ "key": "eventId", "value": "1" },
	{ "key": "status", "value": "ACCEPTED" },
	{ "key": "token", "value": "" }
  ],
  "item": [
	{
	  "name": "Auth - Login",
	  "request": {
		"method": "POST",
		"header": [{ "key": "Content-Type", "value": "application/json" }],
		"body": {
		  "mode": "raw",
		  "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
		},
		"url": { "raw": "{{baseUrl}}/auth/login" }
	  },
	  "event": [
		{
		  "listen": "test",
		  "script": {
			"type": "text/javascript",
			"exec": [
			  "pm.test('Login request succeeded', function () {",
			  "    pm.response.to.have.status(200);",
			  "});",
			  "const json = pm.response.json();",
			  "if (json && json.data && json.data.token) {",
			  "    pm.collectionVariables.set('token', json.data.token);",
			  "}"
			]
		  }
		}
	  ]
	},
	{
	  "name": "Event - Update Approval Status",
	  "request": {
		"method": "PATCH",
		"header": [
		  { "key": "Content-Type", "value": "application/json" },
		  { "key": "Authorization", "value": "Bearer {{token}}" }
		],
		"body": {
		  "mode": "raw",
		  "raw": "{\n  \"status\": \"{{status}}\"\n}"
		},
		"url": { "raw": "{{baseUrl}}/events/{{eventId}}/status" }
	  },
	  "event": [
		{
		  "listen": "test",
		  "script": {
			"type": "text/javascript",
			"exec": [
			  "pm.test('Status update request succeeded', function () {",
			  "    pm.response.to.have.status(200);",
			  "});",
			  "const json = pm.response.json();",
			  "const requestedStatus = pm.collectionVariables.get('status');",
			  "const expectedStatus = requestedStatus === 'REJECTED' ? 'CANCELED' : requestedStatus;",
			  "pm.test('Updated event status matches stored status', function () {",
			  "    pm.expect(json.data.status).to.eql(expectedStatus);",
			  "});"
			]
		  }
		}
	  ]
	},
	{
	  "name": "Event - Verify by ID",
	  "request": {
		"method": "GET",
		"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
		"url": { "raw": "{{baseUrl}}/events/{{eventId}}" }
	  },
	  "event": [
		{
		  "listen": "test",
		  "script": {
			"type": "text/javascript",
			"exec": [
			  "pm.test('Fetch event request succeeded', function () {",
			  "    pm.response.to.have.status(200);",
			  "});",
			  "const json = pm.response.json();",
			  "const requestedStatus = pm.collectionVariables.get('status');",
			  "const expectedStatus = requestedStatus === 'REJECTED' ? 'CANCELED' : requestedStatus;",
			  "pm.test('Fetched event status matches stored status', function () {",
			  "    pm.expect(json.data.status).to.eql(expectedStatus);",
			  "});"
			]
		  }
		}
	  ]
	}
  ]
}

